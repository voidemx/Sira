{
  "name": "sira",
  "version": "1.0.0",
  "description": "Sira a Discord bot",
  "main": "./dist/index.js",
  "type": "module",
  "author": "Void",
  "engines": {
    "node": ">=21.x",
    "pnpm": ">= 10.x"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node ./dist/index.js",
    "dev": "tsx ./src/index.ts"
  },
  "dependencies": {
    "seyfert": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "imports": {
        "#sira/client/*": "./dist/client/*",
        "#sira/config/*": "./dist/config/*",
        "#sira/middlewares/*": "./dist/middlewares/*"
    },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}